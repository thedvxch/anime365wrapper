{
  "name": "anime365wrapper",
  "version": "2.0.0",
  "description": "Modern ESM TypeScript wrapper for the smotret-anime.online (anime365) API with full type support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "vitest run",
    "typecheck:examples": "tsc -p examples/tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedvxch/anime365wrapper.git"
  },
  "bugs": {
    "url": "https://github.com/thedvxch/anime365wrapper/issues"
  },
  "homepage": "https://github.com/thedvxch/anime365wrapper#readme",
  "keywords": [
    "anime",
    "typescript",
    "api",
    "wrapper",
    "smotret-anime",
    "anime365",
    "esm",
    "nodejs"
  ],
  "author": "ragedrugg",
  "contributors": [
    "thedvxch"
  ],
  "license": "MIT",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^3.2.7",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0"
  }
}
